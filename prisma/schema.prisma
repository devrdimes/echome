generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pg_trgm, vector]
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------
enum PlanTier {
  FREE
  PRO
  ULTIMATE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  PAUSED
  INCOMPLETE
}

enum ContentSort {
  CONVERSATION
  WRITING
  VOICE
  JOURNAL
  FEEDBACK
  BEHAVIOR
}

enum ProfileStatus {
  DRAFT
  GENERATING
  READY
  FAILED
}

enum ReflectionMood {
  VERY_LOW
  LOW
  NEUTRAL
  HIGH
  VERY_HIGH
}

enum HabitStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum SortOfCompletion {
  DONE
  SKIPPED
  PARTIAL
}

enum Role {
  USER
  ADMIN
}

enum AchievementKind {
  FIRST_REPORT
  STREAK_7
  STREAK_30
  STREAK_100
  REFLECTION_10
  REFLECTION_50
  HABIT_MASTER
  GOAL_REACHED
  SHARED_REPORT
  ALL_SECTIONS
  EARLY_ADOPTER
}

enum SeasonName {
  SPRING
  SUMMER
  AUTUMN
  WINTER
}

enum AIJobState {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  RETRYING
}

enum TraitCategory {
  COMMUNICATION
  LEADERSHIP
  LEARNING
  RELATIONSHIP
  EMOTIONAL
  DECISION_MAKING
  STRESS
  BLIND_SPOT
  HIDDEN_STRENGTH
  GROWTH
  CORE
}

// ---------------------------------------------------------------------------
// Auth.js Core: User → Account → Session
// ---------------------------------------------------------------------------
model User {
  id            String    @id @default(cuid())
  name          String?   @db.VarChar(120)
  email         String    @unique @db.VarChar(255)
  email_verified DateTime? @map("email_verified")
  image         String?   @db.VarChar(2048)
  role          Role      @default(USER)

  // Gamification
  total_xp       Int      @default(0) @map("total_xp")
  level          Int      @default(1)
  current_streak Int      @default(0) @map("current_streak")
  longest_streak Int      @default(0) @map("longest_streak")
  last_streak_day DateTime? @map("last_streak_day")

  // Entitlements
  plan_tier           PlanTier           @default(FREE) @map("plan_tier")
  subscription_status SubscriptionStatus @default(ACTIVE) @map("subscription_status")
  trial_ends_at       DateTime?          @map("trial_ends_at")

  // Usage caps
  reports_generated_this_cycle Int      @default(0) @map("reports_generated_this_cycle")
  reflections_this_cycle       Int      @default(0) @map("reflections_this_cycle")
  future_sims_this_cycle       Int      @default(0) @map("future_sims_this_cycle")
  cycle_started_at             DateTime @default(now()) @map("cycle_started_at")

  // Relations
  accounts         Account[]
  sessions         Session[]
  subscription     Subscription?
  content          ContentSource[]
  trait_claims     TraitClaim[]
  profile_versions ProfileVersion[]
  profile_current  ProfileCurrent?
  reflections      Reflection[]
  future_scenarios FutureScenario[]
  habits           Habit[]
  habit_logs       HabitLog[]
  goals            Goal[]
  achievements     UserAchievement[]
  missions         UserMission[]
  season_progress  SeasonProgress[]
  share_cards      ShareCard[]
  audit_logs       AuditLog[]
  ai_jobs          AIJob[]
  notifications    Notification[]
  feature_flags    UserFeatureFlag[]

  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  @@index([plan_tier])
  @@index([subscription_status])
  @@index([role])
  @@map("users")
}

model Account {
  id                  String  @id @default(cuid())
  user_id             String  @map("user_id")
  type                String
  provider            String
  provider_account_id String  @map("provider_account_id")
  refresh_token       String? @db.Text @map("refresh_token")
  access_token        String? @db.Text @map("access_token")
  expires_at          Int?    @map("expires_at")
  token_type          String? @map("token_type")
  scope               String?
  id_token            String? @db.Text @map("id_token")
  session_state       String? @map("session_state")

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @map("created_at")

  @@unique([provider, provider_account_id])
  @@index([user_id])
  @@map("accounts")
}

model Session {
  id            String   @id @default(cuid())
  session_token String   @unique @map("session_token")
  user_id       String   @map("user_id")
  expires       DateTime

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @map("created_at")

  @@index([user_id])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---------------------------------------------------------------------------
// Content ingestion
// ---------------------------------------------------------------------------
model ContentSource {
  id             String      @id @default(cuid())
  user_id        String      @map("user_id")
  sort           ContentSort
  title          String?     @db.VarChar(200)
  body           String      @db.Text
  metadata       Json        @default("{}")
  active         Boolean     @default(true)
  token_estimate Int         @default(0) @map("token_estimate")

  user        User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  trait_claims TraitClaim[]

  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  @@index([user_id, sort, active])
  @@index([created_at])
  @@map("content_sources")
}

model TraitClaim {
  id          String        @id @default(cuid())
  user_id     String        @map("user_id")
  source_id   String        @map("source_id")
  category    TraitCategory
  label       String        @db.VarChar(120)
  description String        @db.Text
  confidence  Float         @default(0.5)
  quote       String?       @db.Text
  polarity    Float         @default(0)

  content_source ContentSource @relation(fields: [source_id], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  profile_links  TraitLink[]

  created_at DateTime @default(now()) @map("created_at")

  @@index([user_id, category])
  @@index([source_id])
  @@map("trait_claims")
}

// ---------------------------------------------------------------------------
// Personality profile version graph
// ---------------------------------------------------------------------------
model ProfileVersion {
  id          String        @id @default(cuid())
  user_id     String        @map("user_id")
  version     Int
  status      ProfileStatus @default(DRAFT)
  report      Json          @default("{}")
  summary     String        @db.Text
  confidence  Float         @default(0.5)
  source_ids  String[]      @default([]) @map("source_ids")
  token_usage Int           @default(0) @map("token_usage")
  cost_usd    Float         @default(0) @map("cost_usd")
  model_tag   String        @db.VarChar(120) @map("model_tag")
  error_message String?     @db.Text @map("error_message")

  user        User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  trait_links TraitLink[]
  current_for ProfileCurrent?
  share_cards ShareCard[]

  created_at DateTime @default(now()) @map("created_at")

  @@unique([user_id, version])
  @@index([user_id, status])
  @@map("profile_versions")
}

model ProfileCurrent {
  user_id            String @id @map("user_id")
  profile_version_id String @map("profile_version_id")

  user    User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  version ProfileVersion @relation(fields: [profile_version_id], references: [id], onDelete: Cascade)

  updated_at DateTime @updatedAt @map("updated_at")

  @@map("profile_current")
}

model TraitLink {
  id                 String @id @default(cuid())
  profile_version_id String @map("profile_version_id")
  trait_claim_id     String @map("trait_claim_id")
  weight             Float  @default(1)

  version     ProfileVersion @relation(fields: [profile_version_id], references: [id], onDelete: Cascade)
  trait_claim TraitClaim     @relation(fields: [trait_claim_id], references: [id], onDelete: Cascade)

  @@unique([profile_version_id, trait_claim_id])
  @@index([trait_claim_id])
  @@map("trait_links")
}

// ---------------------------------------------------------------------------
// Reflections
// ---------------------------------------------------------------------------
model Reflection {
  id       String         @id @default(cuid())
  user_id  String         @map("user_id")
  date     DateTime       @db.Date
  body     String         @db.Text
  mood     ReflectionMood @default(NEUTRAL)
  analysis Json           @default("{}")
  analyzed Boolean        @default(false)
  tags     String[]       @default([])

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  @@unique([user_id, date])
  @@index([user_id, date])
  @@map("reflections")
}

// ---------------------------------------------------------------------------
// Future Scenarios & Goals
// ---------------------------------------------------------------------------
model FutureScenario {
  id                  String   @id @default(cuid())
  user_id             String   @map("user_id")
  goal_id             String?  @map("goal_id")
  title               String   @db.VarChar(200)
  scenario            String   @db.Text
  confidence          Json     @default("{}")
  branches            Json     @default("[]")
  assumptions         String[] @default([])
  disclaimer_snapshot String   @db.Text @map("disclaimer_snapshot")
  model_tag           String   @db.VarChar(120) @map("model_tag")
  token_usage         Int      @default(0) @map("token_usage")
  cost_usd            Float    @default(0) @map("cost_usd")

  user User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  goal Goal? @relation(fields: [goal_id], references: [id], onDelete: SetNull)

  created_at DateTime @default(now()) @map("created_at")

  @@index([user_id, created_at])
  @@map("future_scenarios")
}

model Goal {
  id            String    @id @default(cuid())
  user_id       String    @map("user_id")
  title         String    @db.VarChar(200)
  description   String    @db.Text
  cadence       String    @default("weekly")
  target_metric String?   @db.VarChar(60) @map("target_metric")
  target_value  Float?    @map("target_value")
  progress      Float     @default(0)
  achieved      Boolean   @default(false)
  achieved_at   DateTime? @map("achieved_at")
  archived      Boolean   @default(false)
  habit_ids     String[]  @default([]) @map("habit_ids")
  color         String?   @db.VarChar(20)

  user             User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  future_scenarios FutureScenario[]

  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  @@index([user_id, archived])
  @@map("goals")
}

// ---------------------------------------------------------------------------
// Habits
// ---------------------------------------------------------------------------
model Habit {
  id             String      @id @default(cuid())
  user_id        String      @map("user_id")
  title          String      @db.VarChar(160)
  description    String?     @db.Text
  cadence        String      @default("daily")
  schedule       Json        @default("{}")
  difficulty     Int         @default(3)
  status         HabitStatus @default(ACTIVE)
  total_done     Int         @default(0) @map("total_done")
  best_streak    Int         @default(0) @map("best_streak")
  current_streak Int         @default(0) @map("current_streak")
  goal_id        String?     @map("goal_id")

  user User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  logs HabitLog[]

  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  @@index([user_id, status])
  @@map("habits")
}

model HabitLog {
  id         String           @id @default(cuid())
  user_id    String           @map("user_id")
  habit_id   String           @map("habit_id")
  date       DateTime         @db.Date
  completion SortOfCompletion @default(DONE)
  note       String?          @db.Text
  ai_note    String?          @db.Text @map("ai_note")

  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  habit Habit @relation(fields: [habit_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @map("created_at")

  @@unique([habit_id, date])
  @@index([user_id, date])
  @@map("habit_logs")
}

// ---------------------------------------------------------------------------
// Gamification
// ---------------------------------------------------------------------------
model UserAchievement {
  id         String          @id @default(cuid())
  user_id    String          @map("user_id")
  kind       AchievementKind
  xp_awarded Int             @default(0) @map("xp_awarded")
  metadata   Json            @default("{}")

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  unlocked_at DateTime @default(now()) @map("unlocked_at")

  @@unique([user_id, kind])
  @@index([user_id])
  @@map("user_achievements")
}

model UserMission {
  id          String  @id @default(cuid())
  user_id     String  @map("user_id")
  mission_key String  @db.VarChar(60) @map("mission_key")
  title       String  @db.VarChar(160)
  description String  @db.Text
  type        String  @db.VarChar(40)
  target      Int     @default(1)
  progress    Int     @default(0)
  completed   Boolean @default(false)
  claimed     Boolean @default(false)
  xp_reward   Int     @default(0) @map("xp_reward")
  week_key    String  @db.VarChar(10) @map("week_key")

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  @@unique([user_id, mission_key])
  @@index([user_id, week_key])
  @@map("user_missions")
}

model SeasonProgress {
  id               String     @id @default(cuid())
  user_id          String     @map("user_id")
  season           SeasonName
  year             Int
  xp_this_season   Int        @default(0) @map("xp_this_season")
  tier_reached     Int        @default(0) @map("tier_reached")
  rewards_claimed  String[]   @default([]) @map("rewards_claimed")

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  @@unique([user_id, season, year])
  @@index([user_id])
  @@map("season_progress")
}

// ---------------------------------------------------------------------------
// Share Cards
// ---------------------------------------------------------------------------
model ShareCard {
  id                 String  @id @default(cuid())
  user_id            String  @map("user_id")
  profile_version_id String? @map("profile_version_id")
  title              String  @db.VarChar(120)
  format             String  @default("square")
  accent             String  @db.VarChar(20)
  share_id           String  @unique @default(cuid()) @map("share_id")
  image_url          String? @db.VarChar(2048) @map("image_url")
  payload            Json    @default("{}")
  shared_to          String[] @default([]) @map("shared_to")

  user    User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  version ProfileVersion? @relation(fields: [profile_version_id], references: [id], onDelete: SetNull)

  created_at DateTime @default(now()) @map("created_at")

  @@index([user_id, created_at])
  @@map("share_cards")
}

// ---------------------------------------------------------------------------
// Stripe
// ---------------------------------------------------------------------------
model Subscription {
  id                    String             @id @default(cuid())
  user_id               String             @unique @map("user_id")
  stripe_customer_id    String             @unique @map("stripe_customer_id")
  stripe_subscription_id String?           @unique @map("stripe_subscription_id")
  stripe_price_id       String?            @db.VarChar(200) @map("stripe_price_id")
  status                SubscriptionStatus @default(TRIALING)
  current_period_start  DateTime?          @map("current_period_start")
  current_period_end    DateTime?          @map("current_period_end")
  cancel_at             DateTime?          @map("cancel_at")
  canceled_at           DateTime?          @map("canceled_at")

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("subscriptions")
}

// ---------------------------------------------------------------------------
// AI Jobs
// ---------------------------------------------------------------------------
model AIJob {
  id              String     @id @default(cuid())
  user_id         String     @map("user_id")
  type            String     @db.VarChar(60)
  state           AIJobState @default(QUEUED)
  payload         Json       @default("{}")
  result          Json?
  error           String?    @db.Text
  attempts        Int        @default(0)
  next_attempt_at DateTime   @default(now()) @map("next_attempt_at")

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  @@index([state, next_attempt_at])
  @@index([user_id, type])
  @@map("ai_jobs")
}

// ---------------------------------------------------------------------------
// Audit Log
// ---------------------------------------------------------------------------
model AuditLog {
  id         String  @id @default(cuid())
  user_id    String? @map("user_id")
  action     String  @db.VarChar(80)
  diff       Json    @default("{}")
  ip         String? @db.VarChar(45)
  user_agent String? @db.VarChar(512) @map("user_agent")

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  created_at DateTime @default(now()) @map("created_at")

  @@index([user_id, created_at])
  @@index([action, created_at])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Notifications
// ---------------------------------------------------------------------------
model Notification {
  id      String  @id @default(cuid())
  user_id String  @map("user_id")
  type    String  @db.VarChar(60)
  title   String  @db.VarChar(200)
  body    String  @db.Text
  href    String? @db.VarChar(500)
  read    Boolean @default(false)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @map("created_at")

  @@index([user_id, read, created_at])
  @@map("notifications")
}

// ---------------------------------------------------------------------------
// Feature Flags
// ---------------------------------------------------------------------------
model UserFeatureFlag {
  id      String  @id @default(cuid())
  user_id String  @map("user_id")
  flag    String  @db.VarChar(60)
  value   Boolean @default(false)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @map("created_at")

  @@unique([user_id, flag])
  @@map("user_feature_flags")
}
