# Database (Supabase Postgres pooler)
DATABASE_URL="postgresql://postgres:password@db.id.supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:password@db.id.supabase.co:5432/postgres"

# Auth.js
AUTH_SECRET="generate_a_secret_here"
AUTH_URL="https://your-domain.vercel.app/api/auth"

# OAuth providers (optional)
AUTH_GOOGLE_ID="your_google_id_here"
AUTH_GOOGLE_SECRET="your_google_secret_here"

# NVIDIA / GLM-5.2 (OpenAI-compatible)
NVIDIA_API_KEY="your_nvidia_api_key_here"
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
NVIDIA_MODEL="nvidia/z-ai/glm-5.2"
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""
# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_YEARLY=""
STRIPE_PRICE_ULTIMATE_MONTHLY=""

# UploadThing
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Echo AI"
