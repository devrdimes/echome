# Database (Supabase Postgres pooler)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_NEXTAUTH_URL="http://localhost:3000"

# OAuth providers (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""

# NVIDIA / GLM-5.2 (OpenAI-compatible)
NVIDIA_API_KEY=""
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
NVIDIA_MODEL="nvidia/z-ai/glm-5.2"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_YEARLY=""
STRIPE_PRICE_ULTIMATE_MONTHLY=""

# UploadThing
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Echo AI"
